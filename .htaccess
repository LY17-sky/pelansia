DirectoryIndex index.php

<IfModule mod_rewrite.c>
RewriteEngine On

# BLOCK: direktori data (SQLite database)
RewriteRule ^data/ - [F,L]

# BLOCK: file database dan konfigurasi sensitif
RewriteRule \.db$ - [F,L]
RewriteRule \.sql$ - [F,L]
RewriteRule ^\.git/ - [F,L]

# BLOCK: script setup/testing dari akses publik
RewriteRule ^test_db\.php$ - [F,L]
RewriteRule ^setup\.php$ - [F,L]
RewriteRule ^init_db\.php$ - [F,L]

# Allow file/folder yang benar-benar ada
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# SPA fallback — kirim ke index.php
RewriteRule ^(.*)$ index.php [L]
</IfModule>
